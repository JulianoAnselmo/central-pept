# Banco de dados (Neon, Supabase ou Postgres local via Docker)
DATABASE_URL=postgresql://user:pass@host:5432/db?sslmode=require

# Basic Auth do assistente interno
ASSISTENTE_USER=admin
ASSISTENTE_PASS=troque-isso

# Webhook Kiwify (opcional — se setado, valida assinatura HMAC)
KIWIFY_WEBHOOK_SECRET=

# Kiwify URLs de checkout (já existiam)
NEXT_PUBLIC_KIWIFY_RETATRUTIDA=
NEXT_PUBLIC_KIWIFY_GHKCU=
NEXT_PUBLIC_KIWIFY_COMBO_RETA_GHKCU=

# Analytics
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
SITE_URL=https://centralpeptideos.com.br
